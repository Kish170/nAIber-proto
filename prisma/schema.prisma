generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  caregiverProfile CaregiverProfile?
  elderlyProfile   ElderlyProfile?
  sessions         Session[]

  @@map("users")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ElderlyProfile {
  id                    String                @id @default(uuid())
  authUserId            String?               @unique
  name                  String
  age                   Int?
  phone                 String                @unique
  email                 String?               @unique
  gender                Gender?
  educationLevel        EducationLevel?
  interests             String[]
  dislikes              String[]
  callFrequency         CheckInFrequency      @default(DAILY)
  preferredCallTime     DateTime              @db.Time(6)
  isFirstCall           Boolean               @default(true)
  enableHealthCheckIns  Boolean               @default(false)
  hasWebAccess          Boolean               @default(false)
  activationStatus      ActivationStatus      @default(PENDING)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  lastCallAt            DateTime?
  callLogs              CallLog[]
  caregiverLinks        CaregiverUserLink[]
  cognitiveBaselines    CognitiveBaseline[]
  cognitiveTestResults  CognitiveTestResult[]
  conversationSummaries ConversationSummary[]
  conversationTopics    ConversationTopic[]
  authUser              User?                 @relation(fields: [authUserId], references: [id])
  emergencyContact      EmergencyContact?
  healthCheckLogs       HealthCheckLog[]
  wellbeingLogs         WellbeingLog[]
  medicationLogs        MedicationLog[]
  conditionLogs         HealthConditionLog[]
  healthBaseline        HealthBaseline?
  notifications         Notification[]
  trustedContacts       TrustedContact[]
  healthConditions      UserHealthCondition[]
  medications           UserMedication[]
  callEvents            CallEvent[]
  iadlAssessments       IadlAssessment[]
  cognitiveSelfReports  CognitiveSelfReport[]
  indirectSignals       IndirectSignal[]

  @@map("elderly_profiles")
}

model CaregiverProfile {
  id           String              @id @default(uuid())
  authUserId   String              @unique
  name         String
  phone        String?
  relationship Relationship
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  authUser     User                @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  managedUsers CaregiverUserLink[]

  @@map("caregiver_profiles")
}

model CaregiverUserLink {
  id                 String           @id @default(uuid())
  caregiverProfileId String
  elderlyProfileId   String
  isPrimary          Boolean          @default(false)
  status             LinkStatus       @default(ACTIVE)
  createdAt          DateTime         @default(now())
  caregiverProfile   CaregiverProfile @relation(fields: [caregiverProfileId], references: [id], onDelete: Cascade)
  elderlyProfile     ElderlyProfile   @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@unique([caregiverProfileId, elderlyProfileId])
  @@index([elderlyProfileId])
  @@map("caregiver_user_links")
}

model EmergencyContact {
  id                  String         @id @default(uuid())
  elderlyProfileId    String         @unique
  name                String
  phone               String
  email               String?
  relationship        String
  smsEnabled          Boolean        @default(true)
  notifyOnMissedCalls Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  elderlyProfile      ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId])
  @@map("emergency_contacts")
}

model UserHealthCondition {
  id                   String                @id @default(uuid())
  elderlyProfileId     String
  condition            String
  severity             String?
  diagnosedAt          DateTime?
  notes                String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  medicationConditions MedicationCondition[]
  conditionLogs        HealthConditionLog[]
  baselineConditions   HealthBaselineCondition[]
  elderlyProfile       ElderlyProfile        @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@unique([elderlyProfileId, condition])
  @@index([elderlyProfileId, isActive])
  @@map("user_health_conditions")
}

model UserMedication {
  id                   String                @id @default(uuid())
  elderlyProfileId     String
  name                 String
  dosage               String
  frequency            Json
  startedAt            DateTime?
  endedAt              DateTime?
  notes                String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  medicationConditions MedicationCondition[]
  medicationLogs       MedicationLog[]
  baselineMedications  HealthBaselineMedication[]
  elderlyProfile       ElderlyProfile        @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@unique([elderlyProfileId, name])
  @@index([elderlyProfileId, isActive])
  @@map("user_medications")
}

model CallLog {
  id                       String               @id @default(uuid())
  elderlyProfileId         String
  callType                 CallType             @default(GENERAL)
  scheduledTime            DateTime
  endTime                  DateTime?
  status                   CallStatus           @default(PENDING)
  outcome                  CallOutcome?
  noAnswerCount            Int                  @default(0)
  retryCount               Int                  @default(0)
  nextRetryTime            DateTime?
  twilioCallSid            String?
  elevenlabsConversationId String?
  checkInCompleted         Boolean
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  elderlyProfile           ElderlyProfile       @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  cognitiveTestResult      CognitiveTestResult?
  conversationSummary      ConversationSummary?
  healthCheckLog           HealthCheckLog?
  healthCallOpening        HealthCallOpening?
  indirectSignals          IndirectSignal[]

  @@index([elderlyProfileId, scheduledTime])
  @@index([status])
  @@index([scheduledTime])
  @@index([elderlyProfileId, createdAt])
  @@index([elderlyProfileId, callType])
  @@map("call_logs")
}

model ConversationSummary {
  id                    String                       @id @default(uuid())
  elderlyProfileId      String
  conversationId        String                       @unique
  summaryText           String
  durationMinutes       Int?
  topicsDiscussed       String[]
  keyHighlights         Json?
  createdAt             DateTime                     @default(now())
  callLogId             String?                      @unique
  callLog               CallLog?                     @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  elderlyProfile        ElderlyProfile               @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  conversationTopicRefs ConversationTopicReference[]

  @@index([elderlyProfileId, createdAt])
  @@map("conversation_summaries")
}

model ConversationTopic {
  id                     String                       @id @default(uuid())
  elderlyProfileId       String
  topicName              String
  variations             String[]
  category               String?
  topicEmbedding         Float[]
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  conversationReferences ConversationTopicReference[]
  elderlyProfile         ElderlyProfile               @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@unique([elderlyProfileId, topicName])
  @@index([elderlyProfileId, updatedAt])
  @@index([updatedAt])
  @@map("conversation_topics")
}

model ConversationTopicReference {
  id                    String              @id @default(uuid())
  conversationSummaryId String
  conversationTopicId   String
  mentionedAt           DateTime            @updatedAt
  conversationSummary   ConversationSummary @relation(fields: [conversationSummaryId], references: [id], onDelete: Cascade)
  conversationTopic     ConversationTopic   @relation(fields: [conversationTopicId], references: [id], onDelete: Cascade)

  @@unique([conversationSummaryId, conversationTopicId])
  @@index([conversationTopicId])
  @@map("conversation_topic_references")
}

model CallEvent {
  id               String         @id @default(uuid())
  elderlyProfileId String
  conversationId   String
  eventType        String
  description      String
  severity         String?
  detectedAt       DateTime       @default(now())
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, detectedAt])
  @@index([conversationId])
  @@map("call_events")
}

model HealthCheckLog {
  id               String         @id @default(uuid())
  elderlyProfileId String
  conversationId   String
  callLogId        String?        @unique
  answers          Json
  createdAt        DateTime       @default(now())
  callLog          CallLog?           @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  elderlyProfile   ElderlyProfile     @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  wellbeingLog     WellbeingLog?
  medicationLogs   MedicationLog[]
  conditionLogs    HealthConditionLog[]

  @@index([elderlyProfileId, createdAt])
  @@map("health_check_logs")
}

model HealthCallOpening {
  id            String                       @id @default(uuid())
  callLogId     String                       @unique
  callLog       CallLog                      @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  sentiment     HealthCallOpeningSentiment
  statedConcern String?
  disposition   HealthCallOpeningDisposition
  endReason     String?
  createdAt     DateTime                     @default(now())

  @@index([callLogId])
  @@map("health_call_openings")
}

enum HealthCallOpeningSentiment {
  WELL
  POORLY
  AMBIGUOUS
}

enum HealthCallOpeningDisposition {
  PROCEEDED
  ENDED_NOT_READY
  REDIRECTED_GENERAL
}

enum HealthQuestionTopic {
  SYMPTOM
  MEDICATION_SIDE_EFFECT
  SLEEP
  PAIN
  MOOD
  MOBILITY
  APPETITE
  COGNITION_SELF_REPORT
  OTHER_HEALTH
}

model HealthBaseline {
  id               String                     @id @default(uuid())
  elderlyProfileId String                     @unique
  callsIncluded    Int                        @default(0)
  avgWellbeing     Float?
  avgSleepQuality  Float?
  computedAt       DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  elderlyProfile   ElderlyProfile             @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  symptoms         HealthBaselineSymptom[]
  medications      HealthBaselineMedication[]
  conditions       HealthBaselineCondition[]

  @@map("health_baselines")
}

model HealthBaselineSymptom {
  id         String        @id @default(uuid())
  baselineId String
  symptom    String
  count      Int
  baseline   HealthBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)

  @@index([baselineId])
  @@map("health_baseline_symptoms")
}

model HealthBaselineMedication {
  id             String         @id @default(uuid())
  baselineId     String
  medicationId   String
  medicationName String
  takenCount     Int
  totalCount     Int
  adherenceRate  Int
  baseline       HealthBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  medication     UserMedication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@unique([baselineId, medicationId])
  @@index([baselineId])
  @@map("health_baseline_medications")
}

model HealthBaselineCondition {
  id             String                @id @default(uuid())
  baselineId     String
  conditionId    String
  conditionName  String
  latestSeverity ConditionSeverity?
  latestChange   ConditionChangeStatus?
  baseline       HealthBaseline        @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  condition      UserHealthCondition   @relation(fields: [conditionId], references: [id], onDelete: Cascade)

  @@unique([baselineId, conditionId])
  @@index([baselineId])
  @@map("health_baseline_conditions")
}

model MedicationCondition {
  id                String              @id @default(uuid())
  medicationId      String
  healthConditionId String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  healthCondition   UserHealthCondition @relation(fields: [healthConditionId], references: [id], onDelete: Cascade)
  medication        UserMedication      @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@unique([medicationId, healthConditionId])
  @@index([medicationId])
  @@index([healthConditionId])
  @@map("medication_conditions")
}

model CognitiveTestResult {
  id                      String         @id @default(uuid())
  elderlyProfileId        String
  conversationId          String         @unique
  callLogId               String?        @unique
  source                  String         @default("voice")
  modality                String         @default("phone_call")
  sessionIndex            Int
  wordListUsed            String
  digitSetUsed            Int
  letterUsed              String
  abstractionSetUsed      Int
  vigilanceSetUsed        Int
  domainScores            Json
  taskResponses           Json
  stabilityIndex          Float?
  isPartial               Boolean        @default(false)
  wellbeingCheckResponses Json?
  distressDetected        Boolean        @default(false)
  deferralReason          String?
  sessionConfidence       Float?         // 0-1, model-aggregated from per-signal confidences. Nullable v1.
  completedAt             DateTime       @default(now())
  callLog                 CallLog?       @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  elderlyProfile          ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, completedAt])
  @@index([elderlyProfileId, sessionIndex])
  @@map("cognitive_test_results")
}

model CognitiveBaseline {
  id               String         @id @default(uuid())
  elderlyProfileId String
  featureVector    Json
  rawValues        Json
  domainBaselines  Json
  version          Int
  callsIncluded    Int            @default(0)
  baselineLocked   Boolean        @default(false) // true after baselineCallTarget reached (default 3)
  createdAt        DateTime       @default(now())
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, version])
  @@map("cognitive_baselines")
}

model TrustedContact {
  id                     String                     @id @default(uuid())
  elderlyProfileId       String
  name                   String
  relationship           String
  knownDurationYears     Int
  contactFrequency       ContactFrequency
  reliabilityTier        ReliabilityTier
  isPrimary              Boolean                    @default(false) // Only the primary caregiver may submit IQCODE / TrustedContactSubmission. App enforces exactly one per elder.
  informantConcernIndex  Float?
  weightedInformantIndex Float?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  submissions            TrustedContactSubmission[]
  iadlAssessments        IadlAssessment[]
  elderlyProfile         ElderlyProfile             @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId])
  @@index([elderlyProfileId, isPrimary])
  @@map("trusted_contacts")
}

model TrustedContactSubmission {
  id                    String         @id @default(uuid())
  trustedContactId      String
  submissionType        SubmissionType
  structuredResponses   Json
  openTextResponses     Json?
  referencePointNote    String?
  rawScore              Int
  informantConcernIndex Float
  createdAt             DateTime       @default(now())
  trustedContact        TrustedContact @relation(fields: [trustedContactId], references: [id], onDelete: Cascade)

  @@index([trustedContactId, createdAt])
  @@map("trusted_contact_submissions")
}

model Notification {
  id               String             @id @default(uuid())
  elderlyProfileId String
  type             NotificationType
  status           NotificationStatus @default(PENDING)
  title            String
  body             String
  metadata         Json?
  createdAt        DateTime           @default(now())
  readAt           DateTime?
  elderlyProfile   ElderlyProfile     @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, createdAt])
  @@map("notifications")
}

model WellbeingLog {
  id               String         @id @default(uuid())
  healthCheckLogId String         @unique
  elderlyProfileId String
  conversationId   String         @unique
  overallWellbeing Int?
  sleepQuality     Int?
  physicalSymptoms String[]
  generalNotes     String?
  concerns         String[]
  positives        String[]
  createdAt        DateTime       @default(now())
  healthCheckLog   HealthCheckLog @relation(fields: [healthCheckLogId], references: [id], onDelete: Cascade)
  elderlyProfile   ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, createdAt])
  @@map("wellbeing_logs")
}

model MedicationLog {
  id                String         @id @default(uuid())
  healthCheckLogId  String
  elderlyProfileId  String
  conversationId    String
  medicationId      String
  medicationTaken   Boolean?
  notes             String?
  adherenceContext  String?        // 'specific_date' | 'general_period'
  takenAt           DateTime?      // specific date (daily call)
  periodStart       DateTime?      // period start (weekly call)
  periodEnd         DateTime?      // period end (weekly call)
  adherenceRating   String?        // 'always'|'mostly'|'sometimes'|'rarely' (weekly call)
  createdAt         DateTime       @default(now())
  healthCheckLog    HealthCheckLog @relation(fields: [healthCheckLogId], references: [id], onDelete: Cascade)
  medication        UserMedication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  elderlyProfile    ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, createdAt])
  @@index([medicationId])
  @@map("medication_logs")
}

model HealthConditionLog {
  id                 String              @id @default(uuid())
  healthCheckLogId   String
  elderlyProfileId   String
  conversationId     String
  conditionId        String
  rawNotes           String?
  symptoms           String[]
  severity           String?
  changeFromBaseline String?
  notableFlags       String[]
  createdAt          DateTime            @default(now())
  healthCheckLog     HealthCheckLog      @relation(fields: [healthCheckLogId], references: [id], onDelete: Cascade)
  condition          UserHealthCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  elderlyProfile     ElderlyProfile      @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, createdAt])
  @@index([conditionId])
  @@map("health_condition_logs")
}

model IadlAssessment {
  id                   String         @id @default(uuid())
  elderlyProfileId     String
  trustedContactId     String?        
  source               IadlSource     @default(ONBOARDING)

  telephoneUse         Int            
  shopping             Int
  foodPreparation      Int
  housekeeping         Int
  laundry              Int
  transportation       Int
  medicationManagement Int
  finances             Int

  totalScore           Int            
  notes                String?

  createdAt            DateTime       @default(now())

  elderlyProfile       ElderlyProfile  @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  trustedContact       TrustedContact? @relation(fields: [trustedContactId], references: [id], onDelete: SetNull)

  @@index([elderlyProfileId, createdAt])
  @@index([trustedContactId])
  @@map("iadl_assessments")
}

model CognitiveSelfReport {
  id                              String           @id @default(uuid())
  elderlyProfileId                String
  source                          SelfReportSource @default(ONBOARDING)

  forgetfulnessFrequency          Int
  conversationDifficultyFrequency Int
  repetitionFrequency             Int

  totalConcernScore               Int
  notes                           String?

  createdAt                       DateTime         @default(now())

  elderlyProfile                  ElderlyProfile   @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, createdAt])
  @@map("cognitive_self_reports")
}

model IndirectSignal {
  id                  String         @id @default(uuid())
  elderlyProfileId    String
  callLogId           String
  conversationId      String
  callType            CallType       

  signalType          SignalType
  rawValue            Json          

  confidence          Float         
  confounders         Json  
  provenance          Json      

  sufficiencyMet      Boolean
  insufficiencyReason String?    

  createdAt           DateTime       @default(now())

  elderlyProfile      ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  callLog             CallLog        @relation(fields: [callLogId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, signalType, createdAt])
  @@index([callLogId])
  @@map("indirect_signals")
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum Relationship {
  SPOUSE
  DAUGHTER
  SON
  SIBLING
  FRIEND
  CAREGIVER
  OTHER
}

enum CheckInFrequency {
  DAILY
  WEEKLY
}

enum CallType {
  GENERAL
  HEALTH_CHECK
  COGNITIVE
}

enum CallStatus {
  PENDING
  QUEUED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum CallOutcome {
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  USER_ENDED_EARLY
}

enum NotificationType {
  MISSED_CALLS
  SYSTEM_FAILURE
  HEALTH_CONCERN
  WEEKLY_SUMMARY
  MEDICATION_REMINDER
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum LinkStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum ActivationStatus {
  PENDING
  ACTIVE
  OPTED_OUT
}

enum EducationLevel {
  NO_FORMAL_EDUCATION
  PRIMARY_OR_ELEMENTARY
  SECONDARY_OR_HIGH_SCHOOL
  COLLEGE_OR_TRADE
  BACHELORS_OR_EQUIVALENT
  GRADUATE_OR_POSTGRADUATE
}

enum ReliabilityTier {
  HIGH
  MEDIUM
  LOW
}

enum ContactFrequency {
  DAILY
  WEEKLY
  MONTHLY
  OCCASIONAL
}

enum SubmissionType {
  ONBOARDING
  DRIFT_TRIGGERED
  SCHEDULED_REFRESH
  MANUAL
}

enum ConditionSeverity {
  MILD
  MODERATE
  SEVERE
  UNKNOWN
}

enum ConditionChangeStatus {
  IMPROVED
  STABLE
  WORSE
  UNKNOWN
}

enum AdherenceRating {
  ALWAYS
  MOSTLY
  SOMETIMES
  RARELY
}

enum IadlSource {
  ONBOARDING
  DRIFT_TRIGGERED
  SCHEDULED_REFRESH
  CAREGIVER_INITIATED
}

enum SelfReportSource {
  ONBOARDING
  DRIFT_TRIGGERED
  SCHEDULED_REFRESH
}

enum SignalType {
  LEXICAL_DIVERSITY
  SYNTACTIC_COMPLEXITY
  SEMANTIC_COHERENCE
  DISFLUENCY_RATE
  RESPONSE_LATENCY
}
