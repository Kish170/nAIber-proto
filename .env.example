# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXTAUTH_URL=http://localhost:3003

# Demo auth (set to true to enable credentials login for demo)
DEMO_AUTH_ENABLED=false
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+1xxxxxxxxxx
PHONE_NUMBER=+1xxxxxxxxxx

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_AGENT_ID=
ELEVENLABS_NUMBER_ID=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_AUDIO_FORMAT=ulaw_8000
ELEVENLABS_SAMPLE_RATE=8000
# Set this to the deployed llm-server URL in production
ELEVENLABS_CUSTOM_LLM_URL=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_API_KEY=
QDRANT_URL=
QDRANT_COLLECTION=naiber-conversations

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ngrok (local dev only) ───────────────────────────────────────────────────
NGROK_AUTH_TOKEN=
USE_DYNAMIC_NGROK=true
NGROK_API_URL=http://localhost:4040/api/tunnels

# ─── Static URLs (set USE_DYNAMIC_NGROK=false and fill these for prod) ────────
BASE_URL=
TWILIO_URL=
STREAM_URL=

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_TELEPHONY_URL=http://localhost:3000

# ─── LangSmith (optional tracing) ────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:3004
MCP_HOST_PORT=3004
RAG_MEMORY_SIMILARITY_THRESHOLD=0.45
