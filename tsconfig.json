{
  "compilerOptions": {
    "target": "es2020",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "references": [
    { "path": "packages/shared-core" },
    { "path": "packages/shared-clients" },
    { "path": "packages/shared-data" },
    { "path": "packages/shared-services" },
    { "path": "apps/mcp-server" }
  ]
}
